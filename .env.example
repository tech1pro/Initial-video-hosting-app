# YouTube Data API v3 (server only — never expose to browser)
YOUTUBE_API_KEY=

# Comma- or space-separated: UC… channel ids and/or handles (no @ needed), e.g. hiphopimagination
YOUTUBE_CHANNEL_IDS=hiphopimagination

# Secret for /api/sync/youtube (Authorization: Bearer <token> or ?secret=)
CRON_SECRET=change-me-long-random
